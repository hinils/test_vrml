#VRML V2.0 utf8
# Sample: Simple house shape (VRML 2.0)

Group {
  children [
    # --- Walls ---
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor  0.85 0.75 0.55
          specularColor 0.3  0.3  0.3
          shininess     0.15
          ambientIntensity 0.25
        }
      }
      geometry IndexedFaceSet {
        coord Coordinate {
          point [
            # Bottom face
            -2 0 -1,   2 0 -1,   2 0  1,  -2 0  1,
            # Top of walls
            -2 2 -1,   2 2 -1,   2 2  1,  -2 2  1,
            # Roof peak
            -2 3  0,   2 3  0
          ]
        }
        coordIndex [
          # Front wall
          0 1 5 4 -1
          # Back wall
          3 7 6 2 -1
          # Left wall
          0 4 8 -1
          3 8 7 -1
          0 3 8 -1
          # Right wall
          1 9 5 -1
          2 6 9 -1
          1 2 9 -1
          # Roof left slope
          4 5 9 8 -1
          # Roof right slope
          7 8 9 6 -1
          # Floor
          0 3 2 1 -1
        ]
        solid FALSE
        creaseAngle 0.3
      }
    }
    # --- Door ---
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor  0.45 0.28 0.12
          shininess 0.1
        }
      }
      geometry IndexedFaceSet {
        coord Coordinate {
          point [
            -0.4 0.0 -1.01,
             0.4 0.0 -1.01,
             0.4 1.5 -1.01,
            -0.4 1.5 -1.01
          ]
        }
        coordIndex [ 0 1 2 3 -1 ]
        solid FALSE
      }
    }
  ]
}
