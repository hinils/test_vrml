#VRML V1.0 ascii
# Sample: Multi-colored pyramid (VRML 1.0)

Separator {
    Material {
        diffuseColor  [ 0.3 0.7 0.4 ]
        specularColor [ 0.6 0.6 0.6 ]
        shininess     [ 0.35 ]
    }

    Coordinate3 {
        point [
             0.0  1.5  0.0,
            -1.0 -0.5  1.0,
             1.0 -0.5  1.0,
             1.0 -0.5 -1.0,
            -1.0 -0.5 -1.0
        ]
    }

    IndexedFaceSet {
        coordIndex [
            0, 1, 2, -1,
            0, 2, 3, -1,
            0, 3, 4, -1,
            0, 4, 1, -1,
            1, 4, 3, 2, -1
        ]
    }
}
